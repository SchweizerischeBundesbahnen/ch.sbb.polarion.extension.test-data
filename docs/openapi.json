            "properties": {
              "empty": {
                "type": "boolean"
              }
            },
            "type": "object"
          },
          "parent": {
            "$ref": "#/components/schemas/MultiPart"
          },
          "providers": {
            "$ref": "#/components/schemas/Providers"
          }
        },
        "type": "object"
      },
      "CollectionElementRef": {
        "description": "Reference to a versioned document used as a collection element",
        "properties": {
          "documentName": {
            "type": "string"
          },
          "revision": {
            "type": "string"
          },
          "spaceId": {
            "type": "string"
          }
        },
        "type": "object"
      },
      "CollectionRequest": {
        "description": "Request to create a baseline collection",
        "properties": {
          "description": {
            "type": "string"
          },
          "elements": {
            "items": {
              "$ref": "#/components/schemas/CollectionElementRef"
            },
            "type": "array"
          }
        },
        "type": "object"
      },
      "ContentDisposition": {
        "properties": {
          "creationDate": {
            "format": "date-time",
            "type": "string"
          },
          "fileName": {
            "type": "string"
          },
          "modificationDate": {
            "format": "date-time",
            "type": "string"
          },
          "parameters": {
            "additionalProperties": {
              "type": "string"
            },
            "type": "object"
          },
          "readDate": {
            "format": "date-time",
            "type": "string"
          },
          "size": {
            "format": "int64",
            "type": "integer"
          },
          "type": {
            "type": "string"
          }
        },
        "type": "object"
      },
      "Context": {
        "description": "Represents the context for building URLs related to Polarion services",
        "properties": {
          "baseUrl": {
            "description": "Returns the base URL constructed with the extension context",
            "type": "string"
          },
          "extensionContext": {
            "description": "The extension context used as a base for URL construction",
            "type": "string"
          },
          "restUrl": {
            "description": "Returns the REST API URL constructed with the extension context",
            "type": "string"
          },
          "swaggerUiUrl": {
            "description": "Returns the Swagger UI URL for the REST API",
            "type": "string"
          }
        },
        "type": "object"
      },
      "CrossDocumentLinksRequest": {
        "description": "Request to generate cross-document workitem links",
        "properties": {
          "documents": {
            "description": "Documents to link between (links go between random pairs)",
            "items": {
              "$ref": "#/components/schemas/DocumentRef"
            },
            "type": "array"
          },
          "linkRole": {
            "description": "Workitem link role id",
            "example": "relates_to",
            "type": "string"
          },
          "linksPerWorkItem": {
            "description": "Number of cross-document links per source workitem",
            "example": 2,
            "format": "int32",
            "type": "integer"
          }
        },
        "type": "object"
      },
      "DocumentRef": {
        "description": "Reference to a document by space and name",
        "properties": {
          "documentName": {
            "description": "Document name",
            "example": "doc_1",
            "type": "string"
          },
          "spaceId": {
            "description": "Space identifier",
            "example": "_default",
            "type": "string"
          }
        },
        "type": "object"
      },
      "FormDataBodyPart": {
        "properties": {
          "content": {
            "type": "object"
          },
