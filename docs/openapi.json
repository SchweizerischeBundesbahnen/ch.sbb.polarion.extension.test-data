{
  "openapi": "3.0.1",
  "info": {
    "title": "Test Data REST API",
    "version": "v1"
  },
  "paths": {
    "/api/context": {
      "get": {
        "operationId": "getContext",
        "responses": {
          "default": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Context"
                }
              }
            },
            "description": "Context information"
          }
        },
        "summary": "Returns basic context information of Polarion's extension",
        "tags": [
          "Extension Information"
        ]
      }
    },
    "/api/projects/{projectId}/baselines/{baselineName}": {
      "post": {
        "operationId": "createBaseline",
        "parameters": [
          {
            "in": "path",
            "name": "projectId",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "path",
            "name": "baselineName",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "description",
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "revision",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "201": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BaselineResponse"
                }
              }
            },
            "description": "Baseline successfully created"
          }
        },
        "summary": "Create a project baseline",
        "tags": [
          "Test Data"
        ]
      }
    },
    "/api/projects/{projectId}/collections/{collectionName}": {
      "post": {
        "operationId": "createCollection",
        "parameters": [
          {
            "in": "path",
            "name": "projectId",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "path",
            "name": "collectionName",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CollectionRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Collection successfully created"
          }
        },
        "summary": "Create a baseline collection containing the given documents",
        "tags": [
          "Test Data"
        ]
      }
    },
    "/api/projects/{projectId}/cross-document-links": {
      "post": {
        "operationId": "createCrossDocumentLinks",
        "parameters": [
          {
            "in": "path",
            "name": "projectId",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CrossDocumentLinksRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "format": "int32",
                  "type": "integer"
                }
              }
            },
            "description": "Cross-document links successfully created"
          }
        },
        "summary": "Generate random workitem links between documents",
        "tags": [
          "Test Data"
        ]
      }
    },
    "/api/projects/{projectId}/spaces/{spaceId}/documents/{documentName}": {
      "post": {
        "operationId": "createDocumentWithGeneratedWorkItems",
        "parameters": [
          {
            "in": "path",
            "name": "projectId",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "path",
            "name": "spaceId",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "path",
            "name": "documentName",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "quantity",
            "schema": {
              "default": 100,
              "format": "int32",
              "type": "integer"
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Document successfully created with generated work items"
          },
          "409": {
            "description": "Document with this name already exists"
          }
        },
        "summary": "Create document with generated work items",
        "tags": [
          "Test Data"
        ]
      }
    },
    "/api/projects/{projectId}/spaces/{spaceId}/documents/{documentName}/append": {
      "patch": {
        "operationId": "extendDocumentWithGeneratedWorkItems",
        "parameters": [
          {
            "in": "path",
            "name": "projectId",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "path",
            "name": "spaceId",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "path",
            "name": "documentName",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "quantity",
            "schema": {
              "default": 100,
              "format": "int32",
              "type": "integer"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Document successfully appended with generated work items"
          }
        },
        "summary": "Append generated work items to the document",
        "tags": [
          "Test Data"
        ]
      }
    },
    "/api/projects/{projectId}/spaces/{spaceId}/documents/{documentName}/change-wi-descriptions": {
      "patch": {
        "operationId": "changeDocumentWorkItemDescriptions",
        "parameters": [
          {
            "in": "path",
            "name": "projectId",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "path",
            "name": "spaceId",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "path",
            "name": "documentName",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "interval",
            "schema": {
              "default": 5,
              "format": "int32",
              "type": "integer"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "WorkItem descriptions successfully changed"
          }
        },
        "summary": "Change WorkItem Descriptions",
        "tags": [
          "Test Data"
        ]
      }
    },
    "/api/projects/{projectId}/spaces/{spaceId}/documents/{documentName}/linked-revisions": {
      "post": {
        "operationId": "addLinkedRevisions",
        "parameters": [
          {
            "in": "path",
            "name": "projectId",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "path",
            "name": "spaceId",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "path",
            "name": "documentName",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LinkedRevisionsRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "format": "int32",
                  "type": "integer"
                }
              }
            },
            "description": "Linked revisions successfully added"
          }
        },
        "summary": "Add linked revisions to random workitems of a document",
        "tags": [
          "Test Data"
        ]
      }
    },
    "/api/templates/{projectId}/download": {
      "get": {
        "operationId": "downloadProjectTemplate",
        "parameters": [
          {
            "in": "path",
            "name": "projectId",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "projectGroup",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Template successfully downloaded"
          },
          "400": {
            "description": "Invalid project ID"
          },
          "404": {
            "description": "Template not found"
          }
        },
        "summary": "Download a zipped project template",
        "tags": [
          "Test Data"
        ]
      }
    },
    "/api/templates/{templateId}/hash": {
      "get": {
        "operationId": "getTemplateHash",
        "parameters": [
          {
            "in": "path",
            "name": "templateId",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Template hash successfully retrieved"
          },
          "400": {
            "description": "Invalid template ID"
          },
          "404": {
            "description": "Template or hash not found"
          }
        },
        "summary": "Get the hash of a project template",
        "tags": [
          "Test Data"
        ]
      }
    },
    "/api/templates/{templateId}/{templateHash}": {
      "post": {
        "operationId": "saveProjectTemplate",
        "parameters": [
          {
            "in": "path",
            "name": "templateId",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "path",
            "name": "templateHash",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "properties": {
                  "file": {
                    "$ref": "#/components/schemas/FormDataBodyPart"
                  }
                },
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Template successfully created"
          },
          "400": {
            "description": "Invalid template data or ID"
          }
        },
        "summary": "Upload and save a project template",
        "tags": [
          "Test Data"
        ]
      }
    },
    "/api/version": {
      "get": {
        "operationId": "getVersion",
        "responses": {
          "default": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Version"
                }
              }
            },
            "description": "Version information"
          }
        },
        "summary": "Returns version of Polarion's extension",
        "tags": [
          "Extension Information"
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "BaselineResponse": {
        "description": "Information about a created baseline",
        "properties": {
          "name": {
            "type": "string"
          },
          "revision": {
            "type": "string"
          }
        },
        "type": "object"
      },
      "BodyPart": {
        "properties": {
          "contentDisposition": {
            "$ref": "#/components/schemas/ContentDisposition"
          },
          "entity": {
            "type": "object"
          },
          "headers": {
            "additionalProperties": {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            "properties": {
              "empty": {
                "type": "boolean"
              }
            },
            "type": "object"
          },
          "mediaType": {
            "$ref": "#/components/schemas/MediaType"
          },
          "messageBodyWorkers": {
            "$ref": "#/components/schemas/MessageBodyWorkers"
          },
          "parameterizedHeaders": {
            "additionalProperties": {
              "items": {
                "$ref": "#/components/schemas/ParameterizedHeader"
              },
              "type": "array"
