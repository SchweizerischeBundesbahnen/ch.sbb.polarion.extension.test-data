          },
          "type": {
            "type": "string"
          }
        },
        "type": "object"
      },
      "LinkedRevisionsRequest": {
        "description": "Request to add linked-revision references to random workitems of a document",
        "properties": {
          "comment": {
            "description": "Comment text for the linked revision entry",
            "type": "string"
          },
          "revisions": {
            "description": "Repository revisions to attach as linked revisions",
            "items": {
              "description": "Repository revisions to attach as linked revisions",
              "type": "string"
            },
            "type": "array"
          },
          "workItemsPerRevision": {
            "description": "How many random workitems in the source document each revision is attached to",
            "example": 5,
            "format": "int32",
            "type": "integer"
          }
        },
        "type": "object"
      },
      "MediaType": {
        "properties": {
          "parameters": {
            "additionalProperties": {
              "type": "string"
            },
            "type": "object"
          },
          "subtype": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "wildcardSubtype": {
            "type": "boolean"
          },
          "wildcardType": {
            "type": "boolean"
          }
        },
        "type": "object"
      },
      "MessageBodyWorkers": {
        "type": "object"
      },
